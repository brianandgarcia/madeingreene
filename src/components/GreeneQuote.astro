---
const videoSrc = "/hero.mp4";
---

<section class="relative min-h-[360px] md:min-h-[440px] flex items-center overflow-hidden bg-dark">
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="w-full h-full object-cover"
      aria-hidden="true"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
  </div>

  <div class="absolute inset-0 z-10 bg-[linear-gradient(90deg,rgba(12,12,12,0.88)_0%,rgba(12,12,12,0.68)_48%,rgba(12,12,12,0.82)_100%)]"></div>
  <div class="absolute inset-0 z-10 bg-[radial-gradient(ellipse_70%_80%_at_center,rgba(70,137,32,0.28)_0%,rgba(12,12,12,0)_62%)]"></div>

  <div class="relative z-20 max-w-5xl mx-auto px-6 py-20 md:py-28 text-center" data-reveal>
    <p class="text-primary-light font-semibold text-sm uppercase tracking-[0.24em] mb-6">
      Greene County grit
    </p>
    <blockquote>
      <p class="font-display text-4xl md:text-6xl lg:text-7xl font-extrabold leading-[1.05] text-white text-balance [text-shadow:2px_3px_0_rgba(0,0,0,0.65)]">
        “We fight, get beat, rise, and fight again.”
      </p>
      <footer class="mt-7 text-warm-300 text-sm md:text-base font-semibold tracking-wide">
        Nathanael Greene
      </footer>
    </blockquote>
  </div>
</section>
