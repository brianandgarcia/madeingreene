---
import { projects } from "../data/projects";

// Show only real, launched projects — skip sample concepts still on placeholder art.
const showcase = projects
  .filter((p) => !p.images[0].src.includes("placeholder"))
  .slice(0, 4);

function domainFrom(url?: string) {
  return url ? url.replace(/^https?:\/\//, "").replace(/\/$/, "") : null;
}
---

<section class="py-20 md:py-28 bg-warm-100 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10" data-reveal>
      <div>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Our Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-3">
          Recent Website Projects
        </h2>
      </div>
      <a
        href="/work"
        class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors shrink-0"
      >
        See all our work
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      {showcase.map((project, i) => {
        const domain = domainFrom(project.url);
        const external = Boolean(project.url);
        return (
          <a
            href={project.url ?? "/work"}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
            class="group flex flex-col"
            data-reveal
            style={`--reveal-delay: ${i * 100}ms`}
          >
            <!-- Browser-framed screenshot -->
            <div class="rounded-xl overflow-hidden bg-white ring-1 ring-warm-200 shadow-sm transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_18px_40px_-12px_rgba(70,137,32,0.3)]">
              <div class="flex items-center gap-1.5 px-3 py-2.5 bg-warm-100 border-b border-warm-200">
                <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
                {domain && <span class="ml-3 text-[11px] text-warm-500 truncate">{domain}</span>}
              </div>
              <div class="aspect-[16/10] overflow-hidden bg-warm-200">
                <img
                  src={project.images[0].src}
                  alt={project.images[0].alt}
                  loading="lazy"
                  class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
                />
              </div>
            </div>

            <!-- Caption -->
            <div class="mt-4">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="text-xs font-semibold text-primary uppercase tracking-wider">
                  {project.category}
                </span>
                {external && (
                  <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-[11px] font-semibold text-primary-dark uppercase tracking-wide">
                    Live site
                  </span>
                )}
              </div>
              <h3 class="text-xl font-bold text-dark mb-2 group-hover:text-primary transition-colors">
                {project.name}
              </h3>
              <p class="text-warm-500 text-base leading-relaxed line-clamp-2">{project.description}</p>
              <span class="inline-flex items-center mt-3 text-primary text-sm font-semibold">
                {external ? `Visit ${domain}` : "View project"}
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
