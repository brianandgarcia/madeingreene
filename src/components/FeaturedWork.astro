---
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured).slice(0, 3);
---

<section class="py-20 md:py-28 bg-cream">
  <div class="px-6 md:px-10">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12" data-reveal>
      <div>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Our Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-3">
          Built for neighbors, not strangers.
        </h2>
        <p class="text-warm-500 max-w-xl">
          A few of the businesses we've put online. Every one custom-built.
        </p>
      </div>
      <a
        href="/work"
        class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors shrink-0"
      >
        See all our work
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
      {featured.map((project, i) => (
        <a href="/work" class="group flex flex-col" data-reveal style={`--reveal-delay: ${i * 120}ms`}>
          <div class="aspect-[4/3] bg-warm-200 overflow-hidden rounded-xl mb-5">
            <img
              src={project.images[0].src}
              alt={project.images[0].alt}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <h3 class="text-lg font-bold text-dark mb-2 group-hover:text-primary transition-colors">
            {project.name}
          </h3>
          <p class="text-warm-500 text-sm leading-relaxed line-clamp-3">
            {project.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
