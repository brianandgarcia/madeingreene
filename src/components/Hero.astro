---
---

<section class="relative min-h-[85vh] md:min-h-[90vh] flex items-center overflow-hidden bg-dark">
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="w-full h-full object-cover"
      aria-hidden="true"
    >
      <source src="/hero.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="absolute inset-0 z-10 bg-gradient-to-b from-dark/60 via-dark/55 to-dark/85"></div>
  <div class="absolute inset-0 z-10 bg-[radial-gradient(ellipse_at_center,rgba(0,0,0,0.55),transparent_70%)]"></div>

  <div class="absolute inset-0 z-10 opacity-15">
    <div class="absolute top-20 left-10 w-[32rem] h-[32rem] bg-primary rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-[36rem] h-[36rem] bg-accent rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-20 max-w-5xl mx-auto px-6 py-24 md:py-32 text-center">
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold text-white leading-[1.05] tracking-tight mb-8 [text-shadow:0_2px_30px_rgba(0,0,0,0.85)]">
      Websites for Greene County
      <span class="block md:inline bg-gradient-to-r from-primary-light to-primary-dark bg-clip-text text-transparent [-webkit-background-clip:text] [text-shadow:none] drop-shadow-[0_4px_20px_rgba(0,0,0,0.6)]">farms, trades, and shops.</span>
    </h1>

    <p class="text-lg md:text-2xl text-white leading-relaxed mb-12 max-w-3xl mx-auto [text-shadow:0_2px_16px_rgba(0,0,0,0.85)]">
      Built to get you found on Google, look credible to new customers, and turn visits
      into phone calls — without the monthly agency bill.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5"
      >
        Get a free quote
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="/services"
        class="inline-flex items-center justify-center px-8 py-4 border border-warm-500 bg-white/5 backdrop-blur-sm text-warm-200 font-semibold rounded-xl hover:border-warm-300 hover:text-white hover:bg-white/10 transition-all"
      >
        See what's included
      </a>
    </div>

    <div class="mt-20 grid grid-cols-3 gap-6 md:gap-12 max-w-2xl mx-auto">
      <div>
        <div class="text-2xl md:text-3xl font-bold text-white">Loads in under 1 second</div>
        <div class="text-xs md:text-sm text-warm-400 mt-1">Before visitors bounce</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-bold text-white">No monthly hosting fees</div>
        <div class="text-xs md:text-sm text-warm-400 mt-1">For most small business sites</div>
      </div>
      <div>
        <div class="text-2xl md:text-3xl font-bold text-white">You own every file</div>
        <div class="text-xs md:text-sm text-warm-400 mt-1">Take it anywhere, anytime</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 hidden md:flex flex-col items-center gap-2 text-warm-500">
    <span class="text-xs uppercase tracking-widest">Scroll</span>
    <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
