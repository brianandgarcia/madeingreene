---
const cards = [
  {
    img: "/the-funny-farm.jpg",
    alt: "The Funny Farm website — an agritourism farm in Chuckey, Tennessee",
    label: "funnyfarmtn.com",
    position: "sm:rotate-[-5deg] sm:translate-y-6",
  },
  {
    img: "/freedom-for-tate.jpg",
    alt: "FreedomForTate.org — a local advocacy and awareness website",
    label: "freedomfortate.org",
    position: "hidden sm:block z-10",
  },
  {
    img: "",
    alt: "",
    label: "your-business.com",
    position: "hidden sm:block rotate-[5deg] translate-y-6",
    placeholder: true,
  },
];

const stats = [
  { value: "$950", label: "Starting Price" },
  { value: "100%", label: "Locally Made & Owned" },
  { value: "4–6 Weeks", label: "Typical Turnaround" },
];
---

<!-- Hero + work showcase + stats, all on one dark section -->
<section class="relative overflow-hidden bg-dark">
  <!-- layered gradient backdrop -->
  <div class="pointer-events-none absolute inset-0 hero-mesh"></div>
  <div class="pointer-events-none absolute inset-0 hero-grid"></div>
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="hero-orb hero-orb-1 absolute -top-32 -right-24 w-[38rem] h-[38rem] rounded-full bg-primary/25 blur-3xl"></div>
    <div class="hero-orb hero-orb-2 absolute top-1/3 -left-40 w-[32rem] h-[32rem] rounded-full bg-primary-dark/40 blur-3xl"></div>
    <div class="hero-orb hero-orb-3 absolute -bottom-48 right-1/4 w-[30rem] h-[30rem] rounded-full bg-accent/10 blur-3xl"></div>
  </div>
  <!-- fade the mesh out at the bottom so it meets the next section cleanly -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-dark"></div>

  <div class="relative max-w-6xl mx-auto px-6 pt-28 md:pt-36 pb-20 md:pb-24">
    <!-- Copy left, image right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="hero-delayed-fade">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full bg-white/10 ring-1 ring-white/25 text-xs md:text-sm font-semibold uppercase tracking-[0.16em] text-white">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary-light"></span>
          Proudly based in Greeneville, Tennessee
        </span>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-[1.05] tracking-tight mb-6 text-balance">
          <span id="rotating-adjective" class="text-primary-light" style="transition: opacity 0.3s ease;">Dependable</span>
          websites built for
          <span class="block">
            Greene County's
            <span id="rotating-industry" class="text-primary-light" style="transition: opacity 0.3s ease;">contractors.</span>
          </span>
        </h1>

        <p class="max-w-xl text-lg md:text-xl text-warm-300 leading-relaxed mb-8">
          Made in Greene builds professional, mobile-friendly websites for local businesses, farms, shops,
          makers, and organizations in and around Greene County, Tennessee.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/services"
            class="inline-flex items-center justify-center px-8 py-4 bg-accent text-dark font-semibold rounded-xl hover:bg-accent-dark transition-all hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5"
          >
            View Website Packages
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-4 border border-white/40 bg-white/5 backdrop-blur-sm text-white font-semibold rounded-xl hover:border-white hover:bg-white/10 transition-all"
          >
            Start a Project
          </a>
        </div>
      </div>

      <div class="hero-delayed-fade hero-delayed-fade-buttons">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/60">
          <img
            src="/home-hero-bg.jpg"
            alt="Greeneville Town Hall in Greene County, Tennessee"
            class="w-full aspect-[4/3] object-cover object-[58%_center]"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <p class="mt-3 text-center text-xs md:text-sm text-warm-400">
          Greeneville Town Hall — Taken by Made in Greene
        </p>
      </div>
    </div>

    <!-- Work showcase -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-7 items-end mt-20 md:mt-28">
      {cards.map((card) => (
        <div class:list={["card-fade", card.position]}>
          <div class="rounded-xl overflow-hidden bg-white ring-1 ring-black/10 shadow-2xl shadow-black/40">
            <div class="flex items-center gap-1.5 px-3 py-2.5 bg-warm-100 border-b border-warm-200">
              <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
              <span class="ml-3 text-[11px] text-warm-500 truncate">{card.label}</span>
            </div>
            {card.placeholder ? (
              <div class="w-full aspect-[16/11] bg-primary/5 flex flex-col items-center justify-center text-center px-4">
                <span class="w-11 h-11 rounded-full bg-primary/15 text-primary flex items-center justify-center mb-3">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                </span>
                <span class="font-bold text-dark text-base">Your site could be next</span>
                <span class="text-warm-500 text-xs mt-1">Let's build something local.</span>
              </div>
            ) : (
              <img
                src={card.img}
                alt={card.alt}
                loading="lazy"
                class="w-full aspect-[16/11] object-cover object-top"
              />
            )}
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-primary-light font-semibold text-base md:text-lg mt-16 mb-12">
      Built for the businesses that keep Greene County running.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 text-center">
      {stats.map((stat) => (
        <div>
          <div class="text-4xl md:text-5xl font-extrabold text-white tracking-tight">{stat.value}</div>
          <div class="mt-2 text-sm text-warm-400">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const adjectives = ['Dependable', 'Reliable', 'Affordable', 'Modern'];
  const industries = ['contractors', 'plumbers', 'electricians', 'shops', 'farms', 'churches'];

  const adjEl = document.getElementById('rotating-adjective');
  const indEl = document.getElementById('rotating-industry');

  if (adjEl && indEl) {
    let adjIndex = 0;
    let indIndex = 0;
    setInterval(() => {
      adjEl.style.opacity = '0';
      indEl.style.opacity = '0';
      setTimeout(() => {
        adjIndex = (adjIndex + 1) % adjectives.length;
        indIndex = (indIndex + 1) % industries.length;
        adjEl.textContent = adjectives[adjIndex];
        indEl.textContent = industries[indIndex] + '.';
        adjEl.style.opacity = '1';
        indEl.style.opacity = '1';
      }, 300);
    }, 4500);
  }
</script>

<style>
  /* Radial "mesh" of brand greens over the dark base */
  .hero-mesh {
    background:
      radial-gradient(60% 55% at 78% 12%, rgba(70, 137, 32, 0.32), transparent 60%),
      radial-gradient(55% 50% at 8% 42%, rgba(23, 73, 50, 0.55), transparent 62%),
      radial-gradient(45% 45% at 55% 100%, rgba(142, 175, 62, 0.14), transparent 60%);
  }

  /* Faint grid to give the dark space some structure */
  .hero-grid {
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 56px 56px;
    -webkit-mask-image: radial-gradient(75% 65% at 50% 30%, #000 45%, transparent 100%);
    mask-image: radial-gradient(75% 65% at 50% 30%, #000 45%, transparent 100%);
  }

  /* Slow drifting glow orbs */
  .hero-orb {
    will-change: transform;
  }
  .hero-orb-1 {
    animation: orbDrift1 18s ease-in-out infinite;
  }
  .hero-orb-2 {
    animation: orbDrift2 22s ease-in-out infinite;
  }
  .hero-orb-3 {
    animation: orbDrift3 26s ease-in-out infinite;
  }

  @keyframes orbDrift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-3rem, 2.5rem) scale(1.08); }
  }
  @keyframes orbDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(3rem, -2rem) scale(1.06); }
  }
  @keyframes orbDrift3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(2rem, -2.5rem) scale(1.1); }
  }

  .hero-delayed-fade {
    opacity: 0;
    transform: translateY(18px);
    animation: heroDelayedFade 0.45s ease-out 0.15s forwards;
  }

  .hero-delayed-fade-buttons {
    animation-delay: 0.3s;
  }

  @keyframes heroDelayedFade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card-fade {
    opacity: 0;
    animation: cardFade 0.5s ease-out 0.4s forwards;
  }

  @keyframes cardFade {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-delayed-fade,
    .card-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-orb-1,
    .hero-orb-2,
    .hero-orb-3 {
      animation: none;
    }
  }
</style>
