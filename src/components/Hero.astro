---
const cards = [
  {
    img: "/the-funny-farm.jpg",
    alt: "The Funny Farm website — an agritourism farm in Chuckey, Tennessee",
    label: "thefunnyfarmtn.com",
    position: "sm:rotate-[-5deg] sm:translate-y-6",
  },
  {
    img: "/freedom-for-tate.jpg",
    alt: "FreedomForTate.org — a local advocacy and awareness website",
    label: "freedomfortate.org",
    position: "hidden sm:block z-10",
  },
  {
    img: "",
    alt: "",
    label: "your-business.com",
    position: "hidden sm:block rotate-[5deg] translate-y-6",
    placeholder: true,
  },
];

const stats = [
  { value: "$1,250", label: "Starting Price" },
  { value: "100%", label: "Locally Made & Owned" },
  { value: "4–6 Weeks", label: "Typical Turnaround" },
];
---

<section class="relative bg-dark">
  <!-- Video background -->
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="w-full h-full object-cover"
      aria-hidden="true"
    >
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-primary-dark/60 to-dark"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_72%_62%_at_50%_40%,rgba(9,38,25,0.5)_0%,transparent_72%)]"></div>
  </div>

  <!-- Hero text -->
  <div class="relative z-10 flex flex-col items-center text-center px-6 pt-40 md:pt-44 pb-[11rem] sm:pb-[12rem] md:pb-[13rem]">
    <span class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full bg-white/10 backdrop-blur-sm ring-1 ring-white/25 text-xs md:text-sm font-semibold uppercase tracking-[0.16em] text-white">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary-light"></span>
      Proudly based in Greeneville, Tennessee
    </span>

    <h1 class="max-w-5xl text-4xl sm:text-6xl md:text-7xl font-extrabold text-white leading-[1.03] tracking-tight mb-6 text-balance [text-shadow:0_3px_24px_rgba(0,0,0,0.55)]">
      <span id="rotating-adjective" class="bg-gradient-to-r from-[#d7ef75] via-[#a9d958] to-[#5fbf34] bg-clip-text text-transparent [-webkit-background-clip:text] drop-shadow-[0_4px_20px_rgba(0,0,0,0.5)]" style="transition: opacity 0.3s ease;">Dependable</span>
      websites built for
      <span class="block">
        Greene County's
        <span id="rotating-industry" class="bg-gradient-to-r from-[#d7ef75] via-[#a9d958] to-[#5fbf34] bg-clip-text text-transparent [-webkit-background-clip:text] drop-shadow-[0_4px_20px_rgba(0,0,0,0.5)]" style="transition: opacity 0.3s ease;">contractors.</span>
      </span>
    </h1>

    <p class="hero-delayed-fade max-w-2xl text-lg md:text-xl text-white/90 leading-relaxed mb-8 [text-shadow:0_2px_14px_rgba(0,0,0,0.75)]">
      Made in Greene builds professional, mobile-friendly websites for local businesses, farms, shops,
      makers, and organizations in and around Greene County, Tennessee.
    </p>

    <div class="hero-delayed-fade hero-delayed-fade-buttons flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/services"
        class="inline-flex items-center justify-center px-8 py-4 bg-accent text-dark font-semibold rounded-xl hover:bg-accent-dark transition-all hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5"
      >
        View Website Packages
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 border border-white/40 bg-white/5 backdrop-blur-sm text-white font-semibold rounded-xl hover:border-white hover:bg-white/10 transition-all"
      >
        Start a Project
      </a>
    </div>
  </div>

  <!-- Floating showcase cards (straddle hero + dark strip below) -->
  <div class="absolute z-20 inset-x-0 bottom-0 translate-y-1/2">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-7 items-end">
        {cards.map((card) => (
          <div class:list={["card-fade", card.position]}>
            <div class="rounded-xl overflow-hidden bg-white ring-1 ring-black/10 shadow-2xl shadow-black/40">
              <div class="flex items-center gap-1.5 px-3 py-2.5 bg-warm-100 border-b border-warm-200">
                <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
                <span class="ml-3 text-[11px] text-warm-500 truncate">{card.label}</span>
              </div>
              {card.placeholder ? (
                <div class="w-full aspect-[16/11] bg-primary/5 flex flex-col items-center justify-center text-center px-4">
                  <span class="w-11 h-11 rounded-full bg-primary/15 text-primary flex items-center justify-center mb-3">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  </span>
                  <span class="font-bold text-dark text-base">Your site could be next</span>
                  <span class="text-warm-500 text-xs mt-1">Let's build something local.</span>
                </div>
              ) : (
                <img
                  src={card.img}
                  alt={card.alt}
                  loading="lazy"
                  class="w-full aspect-[16/11] object-cover object-top"
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Dark trust + stats strip (receives the floating cards) -->
<section class="bg-dark pt-[10rem] sm:pt-[11rem] md:pt-[12rem] pb-20 md:pb-24">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-primary-light font-semibold text-base md:text-lg mb-12">
      Built for the businesses that keep Greene County running.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
      {stats.map((stat) => (
        <div>
          <div class="text-4xl md:text-5xl font-extrabold text-white tracking-tight">{stat.value}</div>
          <div class="mt-2 text-sm text-warm-400">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const adjectives = ['Dependable', 'Reliable', 'Affordable', 'Modern'];
  const industries = ['contractors', 'plumbers', 'electricians', 'shops', 'farms', 'churches'];

  const adjEl = document.getElementById('rotating-adjective');
  const indEl = document.getElementById('rotating-industry');

  if (adjEl && indEl) {
    let adjIndex = 0;
    let indIndex = 0;
    setInterval(() => {
      adjEl.style.opacity = '0';
      indEl.style.opacity = '0';
      setTimeout(() => {
        adjIndex = (adjIndex + 1) % adjectives.length;
        indIndex = (indIndex + 1) % industries.length;
        adjEl.textContent = adjectives[adjIndex];
        indEl.textContent = industries[indIndex] + '.';
        adjEl.style.opacity = '1';
        indEl.style.opacity = '1';
      }, 300);
    }, 4500);
  }
</script>

<style>
  .hero-delayed-fade {
    opacity: 0;
    transform: translateY(18px);
    animation: heroDelayedFade 0.45s ease-out 0.15s forwards;
  }

  .hero-delayed-fade-buttons {
    animation-delay: 0.3s;
  }

  @keyframes heroDelayedFade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* opacity-only fade so the cards keep their rotate/translate */
  .card-fade {
    opacity: 0;
    animation: cardFade 0.5s ease-out 0.4s forwards;
  }

  @keyframes cardFade {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-delayed-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .card-fade {
      opacity: 1;
      animation: none;
    }
  }
</style>
