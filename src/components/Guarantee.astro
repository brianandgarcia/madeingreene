---
---

<section class="relative bg-dark overflow-hidden">
  <div class="absolute inset-0 opacity-30">
    <div class="absolute -top-32 -left-32 w-[40rem] h-[40rem] bg-primary rounded-full blur-3xl"></div>
    <div class="absolute -bottom-32 -right-32 w-[40rem] h-[40rem] bg-accent rounded-full blur-3xl"></div>
  </div>

  <div class="absolute inset-0 opacity-[0.04]" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 12px);"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16 items-center">
      <div class="md:col-span-5 text-center md:text-left" data-reveal="left">
        <span class="text-primary-light font-semibold text-xs uppercase tracking-[0.25em]">
          Our Promise
        </span>
        <div class="mt-4 flex items-start justify-center md:justify-start gap-3">
          <span class="text-[10rem] md:text-[14rem] leading-none font-extrabold text-white">3</span>
          <div class="pt-6 md:pt-8">
            <div class="text-2xl md:text-3xl font-bold text-primary-light leading-tight">Year</div>
            <div class="text-xl md:text-2xl font-semibold text-warm-300 leading-tight">Guarantee</div>
          </div>
        </div>
      </div>

      <div class="md:col-span-7" data-reveal="right">
        <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-5">
          Your site won't need replacing in two years.
        </h2>
        <p class="text-warm-300 text-lg leading-relaxed mb-8 max-w-2xl">
          Other shops build sites that go stale fast — then charge you to redo them. We don't.
          If your site needs a full rebuild within 3 years just to keep working, we do it free.
          That's the promise.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/services#guarantee"
            class="inline-flex items-center px-6 py-3 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary-dark transition-colors"
          >
            See what's covered
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/vs-godaddy"
            class="inline-flex items-center px-6 py-3 border border-warm-600 text-warm-200 text-sm font-semibold rounded-lg hover:border-warm-400 hover:text-white transition-colors"
          >
            Why not GoDaddy?
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
