---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-warm-400">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-center mb-4" aria-label="Made in Greene — home">
          <img src="/made-in-greene-logo.svg" alt="Made in Greene" class="h-14 w-auto brightness-0 invert opacity-90" />
        </a>
        <p class="text-sm leading-relaxed max-w-sm">
          Affordable websites for Greene County businesses.
          Clear pricing. Local support. No runaround.
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Navigation</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm hover:text-primary transition-colors">Home</a></li>
          <li><a href="/services" class="text-sm hover:text-primary transition-colors">Services</a></li>
          <li><a href="/work" class="text-sm hover:text-primary transition-colors">Work</a></li>
          <li><a href="/vs-godaddy" class="text-sm hover:text-primary transition-colors">Vs. GoDaddy</a></li>
          <li><a href="/about" class="text-sm hover:text-primary transition-colors">About</a></li>
          <li><a href="/contact" class="text-sm hover:text-primary transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact</h4>
        <ul class="space-y-2 text-sm">
          <li>Greene County, TN</li>
          <li>
            <a href="mailto:brian@madeingreene.com" class="hover:text-primary transition-colors">
              brian@madeingreene.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-warm-800 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs">
        &copy; {currentYear} Made in Greene. All rights reserved.
      </p>
      <p class="text-xs">
        Proudly built in Greene County, Tennessee.
      </p>
    </div>
  </div>
</footer>
