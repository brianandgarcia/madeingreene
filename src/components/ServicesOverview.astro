---
const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: "We're locally made and owned.",
    description: "Built right here in Greene County, Tennessee. We know the area, the people, and what it takes to get your business online.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>`,
    title: "Our pricing is honest and upfront.",
    description: "Clear package prices with no surprise renewals or hidden fees. You only pay for what your business actually needs unlike GoDaddy, Wix, or Squarespace.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`,
    title: "You always reach a real person.",
    description: "When you have a question after launch, you reach Brian or Domenique who knows your project — not a support ticket or an overseas call center.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>`,
    title: "We write your content for you.",
    description: "Tell us what you do and we turn it into clear, professional copy. No staring at a blank page or trying to write it yourself.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`,
    title: "Your site is built to get found.",
    description: "Every site ships search-ready, so Greene County customers can find you on Google when they are looking for what you offer.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>`,
    title: "You can run it yourself.",
    description: "We hand off with a real walkthrough, so you can update hours, swap photos, and edit text without calling a developer every time.",
  },
];
---

<section class="py-20 md:py-28 bg-warm-100 border-t border-warm-200" id="services">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16" data-reveal>
      <span class="text-primary font-semibold text-sm uppercase tracking-wider">Why Choose Made in Greene</span>
      <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">
        We help Greene County businesses get online without the headaches.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, i) => (
        <div
          class="group relative overflow-hidden rounded-2xl border border-warm-200 bg-white shadow-sm p-7 transition-all duration-300 hover:-translate-y-1 hover:border-primary/50 hover:shadow-[0_18px_40px_-12px_rgba(70,137,32,0.35)]"
          data-reveal
          style={`--reveal-delay: ${(i % 3) * 100}ms`}
        >
          <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-gradient-to-br from-primary/15 via-primary-light/10 to-transparent"></div>
          <div class="relative">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center text-primary mb-5 bg-primary/10 group-hover:bg-primary group-hover:text-white transition-colors">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-xl font-bold text-dark mb-3 leading-snug">{service.title}</h3>
            <p class="text-warm-600 text-base leading-relaxed">{service.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12" data-reveal>
      <a
        href="/services"
        class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5"
      >
        See Packages & Pricing
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
