---
const currentPath = Astro.url.pathname;

// Top announcement bar — edit or set `show: false` to hide.
const announcement = {
  show: true,
  text: "Now booking new website projects for Greene County businesses.",
  linkLabel: "Get a free quote",
  href: "/contact",
};

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "What We Offer" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const serviceLinks = [
  {
    href: "/services",
    label: "Custom Websites",
    description: "Landing, Business, Growth & Ecommerce sites",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  },
  {
    href: "/services",
    label: "Local SEO Setup",
    description: "Google-ready pages and metadata",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
  },
  {
    href: "/services",
    label: "Copywriting",
    description: "Clear pages written for your business",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>`,
  },
  {
    href: "/services#quote-builder",
    label: "Logo & Brand",
    description: "Identity add-ons when you need them",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
  },
  {
    href: "/services#quote-builder",
    label: "Online Store",
    description: "Shopify store setup for selling online",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 7h14M10 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z" /></svg>`,
  },
  {
    href: "/services",
    label: "Hosting Included",
    description: "For most brochure-style sites",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7a4 4 0 014-4h8a4 4 0 014 4v10a4 4 0 01-4 4H8a4 4 0 01-4-4V7zm4 1h8M8 12h8M8 16h4" /></svg>`,
  },
  {
    href: "/services",
    label: "Care Plans",
    description: "Updates, edits, and direct support",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
  },
  {
    href: "/services#quote-builder",
    label: "Quote Builder",
    description: "Pick options and see the price",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m-6 4h6m-6 4h3M5 3h14a2 2 0 012 2v14l-4-2-4 2-4-2-4 2V5a2 2 0 012-2z" /></svg>`,
  },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-warm-200 shadow-[0_8px_24px_rgba(0,0,0,0.06)]"
>
  {announcement.show && (
    <div class="bg-primary text-white">
      <p class="max-w-6xl mx-auto px-6 py-2 text-center text-xs sm:text-sm font-medium">
        {announcement.text}{" "}
        <a href={announcement.href} class="underline underline-offset-2 font-semibold hover:text-white/80 transition-colors">
          {announcement.linkLabel} →
        </a>
      </p>
    </div>
  )}

  <div
    class="max-w-6xl mx-auto"
  >
    <nav class="px-6 py-[1.125rem] flex items-center justify-between">
      <a href="/" class="flex items-center group" aria-label="MadeinGreene — home">
        <img src="/made-in-greene-logo.svg" alt="Made in Greene" class="h-16 w-auto" />
      </a>

      <div class="hidden md:flex items-center gap-8">
        <ul class="flex items-center gap-6">
        {navLinks.map((link) => (
          <li class={link.label === "Services" ? "relative group/services" : undefined}>
            {link.label === "Services" ? (
              <>
                <a
                  href={link.href}
                  class:list={[
                    "inline-flex items-center gap-1.5 text-lg font-medium transition-colors hover:text-primary",
                    currentPath === link.href ? "text-primary" : "text-dark",
                  ]}
                  aria-haspopup="true"
                >
                  {link.label}
                  <svg class="w-4 h-4 transition-transform group-hover/services:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <div class="pointer-events-none absolute left-0 top-full w-[min(68rem,calc(100vw-3rem))] max-w-[calc(100vw-3rem)] pt-2 opacity-0 translate-y-1 transition-all duration-200 group-hover/services:pointer-events-auto group-hover/services:opacity-100 group-hover/services:translate-y-0 group-focus-within/services:pointer-events-auto group-focus-within/services:opacity-100 group-focus-within/services:translate-y-0">
                  <div class="rounded-xl bg-white shadow-[0_24px_70px_rgba(0,0,0,0.32)] ring-1 ring-dark/10 overflow-hidden">
                    <div class="grid grid-cols-4">
                      {serviceLinks.map((service) => (
                        <a href={service.href} class="group/item p-5 border-r border-b border-warm-200 last:border-r-0 hover:bg-cream transition-colors">
                          <span class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center mb-4 group-hover/item:bg-primary group-hover/item:text-white transition-colors">
                            <Fragment set:html={service.icon} />
                          </span>
                          <span class="block text-sm font-bold text-dark mb-1">{service.label}</span>
                          <span class="block text-xs leading-relaxed text-warm-500">{service.description}</span>
                        </a>
                      ))}
                    </div>
                    <div class="flex items-center justify-between gap-4 px-5 py-4 bg-dark text-white">
                      <span class="text-sm text-warm-300">Not sure what you need? Build a quick estimate.</span>
                      <a href="/services#quote-builder" class="shrink-0 inline-flex items-center px-4 py-2 rounded-lg bg-accent text-dark text-sm font-semibold hover:bg-accent-dark transition-colors">
                        Build your quote
                      </a>
                    </div>
                  </div>
                </div>
              </>
            ) : (
              <a
                href={link.href}
                class:list={[
                  "text-lg font-medium transition-colors hover:text-primary",
                  currentPath === link.href ? "text-primary" : "text-dark",
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
        </ul>

        <a
          href="tel:+14232927294"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white text-base font-semibold rounded-lg hover:bg-primary-dark transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.95l-1.27 1.27a16 16 0 006.32 6.32l1.27-1.27a2 2 0 011.95-.45l2.8.7A2 2 0 0121 17.72V20a2 2 0 01-2 2h-1C9.716 22 2 14.284 2 5V4" />
          </svg>
          423-292-7294
        </a>
      </div>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-dark hover:text-primary transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <div id="mobile-menu" class="hidden md:hidden border-t border-warm-200 bg-white">
      <div class="px-6 py-4 space-y-3">
        {navLinks.map((link) => (
          <>
            <a
              href={link.href}
              class:list={[
                "block text-lg font-medium transition-colors hover:text-primary",
                currentPath === link.href ? "text-primary" : "text-dark",
              ]}
            >
              {link.label}
            </a>
            {link.label === "Services" && (
              <div class="grid grid-cols-2 gap-2 pt-1 pb-2">
                {serviceLinks.slice(0, 6).map((service) => (
                  <a href={service.href} class="flex items-center gap-2 rounded-lg bg-cream px-3 py-2 text-sm text-warm-700 hover:bg-warm-100 hover:text-dark transition-colors">
                    <span class="text-primary shrink-0">
                      <Fragment set:html={service.icon} />
                    </span>
                    <span>{service.label}</span>
                  </a>
                ))}
              </div>
            )}
          </>
        ))}
        <a
          href="tel:+14232927294"
          class="block w-full text-center px-5 py-2.5 bg-primary text-white text-base font-semibold rounded-lg hover:bg-primary-dark transition-colors"
        >
          Call 423-292-7294
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
