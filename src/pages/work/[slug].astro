---
import Layout from "../../layouts/Layout.astro";
import CTA from "../../components/CTA.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects
    .filter((p) => p.slug)
    .map((p) => ({ params: { slug: p.slug! }, props: { project: p } }));
}

const { project } = Astro.props;
const domain = project.url?.replace(/^https?:\/\//, "").replace(/\/$/, "");
const liveHref = project.href ?? project.url;
---

<Layout
  title={`${project.name} — Case Study`}
  description={project.tagline ?? project.description}
>
  <!-- Header -->
  <section class="pt-32 md:pt-40 pb-10 bg-warm-100">
    <div class="max-w-5xl mx-auto px-6">
      <a
        href="/work"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-warm-500 hover:text-primary transition-colors mb-6"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Our Work
      </a>

      <div class="flex items-center gap-3 mb-3">
        <span class="text-primary text-sm font-semibold uppercase tracking-wider">{project.category}</span>
        {liveHref && (
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-[11px] font-semibold text-primary-dark uppercase tracking-wide">
            Live site
          </span>
        )}
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold text-dark leading-[1.05] tracking-tight mb-4">
        {project.name}
      </h1>
      {project.tagline && (
        <p class="text-lg md:text-xl text-warm-600 max-w-2xl leading-relaxed">{project.tagline}</p>
      )}

      {liveHref && (
        <a
          href={liveHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/25"
        >
          Visit {domain ?? "the live site"}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </section>

  <!-- Screenshot -->
  <section class="bg-warm-100 pb-16 md:pb-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="rounded-2xl overflow-hidden ring-1 ring-warm-200 shadow-2xl shadow-dark/10 bg-white">
        <div class="flex items-center gap-1.5 px-4 py-3 bg-warm-100 border-b border-warm-200">
          <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
          {domain && <span class="ml-3 text-xs text-warm-500 truncate">{domain}</span>}
        </div>
        <img src={project.images[0].src} alt={project.images[0].alt} loading="eager" class="w-full" />
      </div>
    </div>
  </section>

  <!-- Meta -->
  {project.meta && (
    <section class="bg-white border-y border-warm-200">
      <div class="max-w-5xl mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-6">
        {project.meta.map((m) => (
          <div>
            <div class="text-xs uppercase tracking-widest text-warm-400 font-bold mb-1">{m.label}</div>
            <div class="text-sm font-semibold text-dark leading-snug">{m.value}</div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- The goal -->
  {project.goal && (
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-3xl mx-auto px-6">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">The goal</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-6">What they needed.</h2>
        <div class="space-y-5 text-lg text-warm-600 leading-relaxed">
          {project.goal.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>
  )}

  <!-- What we built -->
  {project.built && (
    <section class="py-16 md:py-24 bg-warm-100">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-2xl mb-10">
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">What we built</span>
          <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">The work, piece by piece.</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {project.built.map((f) => (
            <div class="bg-white rounded-2xl p-6 border border-warm-200">
              <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-4">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-dark mb-2 leading-snug">{f.title}</h3>
              <p class="text-warm-600 text-base leading-relaxed">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Brand / logo refresh -->
  {project.logo && (
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Brand refresh</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-10">A logo that fits the farm.</h2>
        <div class="inline-block rounded-2xl bg-white ring-1 ring-warm-200 shadow-sm p-8 md:p-12">
          <img src={project.logo.src} alt={project.logo.alt} loading="lazy" class="w-full max-w-sm mx-auto" />
        </div>
      </div>
    </section>
  )}

  <!-- Video -->
  {project.youtubeId && (
    <section class="py-16 md:py-24 bg-warm-100">
      <div class="max-w-4xl mx-auto px-6">
        <div class="max-w-2xl mb-8">
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">Photo & video</span>
          <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">See it in action.</h2>
        </div>
        <div class="relative aspect-video rounded-2xl overflow-hidden ring-1 ring-warm-200 shadow-xl bg-dark">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${project.youtubeId}`}
            title={`${project.name} — video`}
            loading="lazy"
            class="absolute inset-0 w-full h-full border-0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>
  )}

  <!-- Gallery (only when there's more than the hero screenshot) -->
  {project.images.length > 1 && (
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-2xl mb-10">
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">A closer look</span>
          <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">More from the project.</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {project.images.slice(1).map((img) => (
            <div class="rounded-2xl overflow-hidden ring-1 ring-warm-200 shadow-sm">
              <img src={img.src} alt={img.alt} loading="lazy" class="w-full" />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- The result -->
  {project.results && (
    <section class="py-16 md:py-24 bg-primary-dark">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <span class="text-primary-light font-semibold text-sm uppercase tracking-wider">The result</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-8">What it delivers.</h2>
        <ul class="space-y-4 text-left max-w-xl mx-auto">
          {project.results.map((r) => (
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-1 w-6 h-6 rounded-full bg-primary/25 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="text-lg text-white/90 leading-relaxed">{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Testimonial -->
  {project.testimonial && (
    <section class="py-16 md:py-24 bg-cream">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <svg class="w-9 h-9 text-primary/25 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
        </svg>
        <blockquote class="text-xl md:text-2xl font-medium text-dark leading-relaxed mb-6">
          “{project.testimonial.quote}”
        </blockquote>
        <div class="text-sm font-semibold text-dark">{project.testimonial.name}</div>
        <div class="text-sm text-warm-500">{project.testimonial.role}</div>
      </div>
    </section>
  )}

  <CTA />
</Layout>
