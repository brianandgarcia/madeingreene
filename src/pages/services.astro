---
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";

const packages = [
  {
    name: "Starter",
    oneTime: "$1,500",
    monthly: "$0 required",
    careRange: "Optional care plan: $75–150/mo",
    description:
      "Just getting started or need a simple, solid presence online. Perfect for a farm stand, trade business, or new shop.",
    specs: [
      { label: "Pages", value: "1–3" },
      { label: "Load time", value: "< 1s" },
      { label: "Mobile-ready", value: "Yes" },
      { label: "Hosting", value: "Included*" },
      { label: "Uptime target", value: "99.99%" },
      { label: "Revisions", value: "1 round" },
    ],
    included: [
      "Custom-designed site (not a template)",
      "Contact form so customers can reach you",
      "Google Maps embed",
      "Basic Google search setup",
      "Simple content editor you control",
      "Handoff walkthrough (30 min)",
    ],
    notIncluded: [
      { label: "Domain name", note: "~$12–20/yr, paid to registrar — not us" },
      { label: "Stock photos", note: "Free options provided. Premium ~$10–100 each if you want them" },
      { label: "Logo design", note: "$500–1,000 add-on (see below)" },
      { label: "Extra training sessions", note: "$150/hr (see add-ons)" },
    ],
    highlight: false,
    cta: "Get Started",
  },
  {
    name: "Growth",
    oneTime: "$3,500",
    monthly: "$0 required",
    careRange: "Optional care plan: $75–150/mo",
    description:
      "Ready to get serious about bringing in customers. A full site with everything you need to grow.",
    specs: [
      { label: "Pages", value: "5–10" },
      { label: "Load time", value: "< 1s" },
      { label: "Mobile-ready", value: "Yes" },
      { label: "Hosting", value: "Included*" },
      { label: "Uptime target", value: "99.99%" },
      { label: "Revisions", value: "2 rounds" },
    ],
    included: [
      "Custom-designed site (5–10 pages)",
      "Blog or news section",
      "Full Google search optimization",
      "Analytics — see who's visiting",
      "Social media links",
      "Content editor + 1-hour training session",
    ],
    notIncluded: [
      { label: "Domain name", note: "~$12–20/yr, paid to registrar — not us" },
      { label: "Stock photos beyond free tier", note: "~$10–100 each if you want premium" },
      { label: "Logo design", note: "$500–1,000 add-on (see below)" },
      { label: "Online store / booking", note: "Upgrade to Premium" },
    ],
    highlight: true,
    cta: "Most Popular",
  },
  {
    name: "Premium",
    oneTime: "$5,000+",
    monthly: "$0 required",
    careRange: "Optional care plan: $75–150/mo",
    description:
      "The whole package. Online store, booking system, or custom features — whatever your business needs to run.",
    specs: [
      { label: "Pages", value: "10+" },
      { label: "Load time", value: "< 1s" },
      { label: "Mobile-ready", value: "Yes" },
      { label: "Hosting", value: "Included*" },
      { label: "Uptime target", value: "99.99%" },
      { label: "Revisions", value: "Unlimited" },
    ],
    included: [
      "Custom design, 10+ pages",
      "Online store or booking system",
      "Logo & brand identity",
      "Priority search optimization",
      "Performance monitoring",
      "Full training + written how-to guide",
    ],
    notIncluded: [
      { label: "Domain name", note: "~$12–20/yr, paid to registrar — not us" },
      { label: "Payment processing fees", note: "If you sell online, Stripe/Square charge ~2.9% + 30¢" },
      { label: "Stock photos beyond free tier", note: "~$10–100 each if you want premium" },
      { label: "Professional photography", note: "Quoted separately" },
    ],
    highlight: false,
    cta: "Let's Talk",
  },
];

const addons = [
  { name: "Logo & Brand Identity", price: "$500–1,000" },
  { name: "Google Business Profile Setup", price: "$200" },
  { name: "Social Media Starter Kit", price: "$300" },
  { name: "Professional Photography", price: "Quote" },
  { name: "Email Setup (Your Own Domain)", price: "$150" },
  { name: "Extra Training Session (1 hr)", price: "$150" },
  { name: "Monthly Care Plan", price: "$75–150/mo" },
];
---

<Layout
  title="Services & Pricing"
  description="Honest pricing for custom websites built for small businesses in Greene County, TN. Every package shows exactly what you pay for — and what you don't."
>
  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-6">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Services & Pricing</span>
        <h1 class="text-3xl md:text-5xl font-bold text-dark mt-3 mb-4">
          Honest pricing. No fine print.
        </h1>
        <p class="text-warm-500 max-w-2xl mx-auto">
          Every package comes with a plain-English breakdown of what you pay,
          what's included, and what's not. Inspired by the FCC's broadband pricing labels —
          because you deserve the same transparency when buying a website.
        </p>
      </div>

      <div class="text-center mb-16">
        <a href="#why-labels" class="inline-flex items-center text-primary text-sm font-semibold hover:text-primary-dark transition-colors">
          Why we show pricing this way
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {packages.map((pkg) => (
          <div
            class:list={[
              "bg-white rounded-xl overflow-hidden flex flex-col relative",
              pkg.highlight
                ? "ring-2 ring-primary shadow-xl shadow-primary/10"
                : "border-2 border-dark",
            ]}
          >
            {pkg.highlight && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-accent text-white text-xs font-semibold rounded-full z-10">
                Most Popular
              </div>
            )}

            <div class="bg-dark text-white px-6 py-4 border-b-4 border-dark">
              <div class="text-[10px] uppercase tracking-widest text-warm-400 mb-1">
                Website Facts
              </div>
              <div class="text-2xl font-extrabold">{pkg.name} Plan</div>
            </div>

            <div class="px-6 py-5 border-b border-warm-200">
              <div class="flex items-baseline justify-between mb-2">
                <span class="text-sm font-semibold text-dark uppercase tracking-wider">One-time build</span>
                <span class="text-3xl font-extrabold text-dark">{pkg.oneTime}</span>
              </div>
              <div class="flex items-baseline justify-between mb-1">
                <span class="text-sm font-semibold text-warm-600 uppercase tracking-wider">Monthly required</span>
                <span class="text-lg font-bold text-primary">{pkg.monthly}</span>
              </div>
              <p class="text-xs text-warm-500 mt-2">{pkg.careRange}</p>
            </div>

            <div class="px-6 py-4 border-b border-warm-200">
              <div class="text-xs font-bold text-dark uppercase tracking-widest mb-3">
                Specs
              </div>
              <dl class="space-y-1.5">
                {pkg.specs.map((spec) => (
                  <div class="flex justify-between text-sm">
                    <dt class="text-warm-600">{spec.label}</dt>
                    <dd class="font-semibold text-dark">{spec.value}</dd>
                  </div>
                ))}
              </dl>
            </div>

            <div class="px-6 py-4 border-b border-warm-200">
              <div class="text-xs font-bold text-dark uppercase tracking-widest mb-3">
                What's included (no extra charge)
              </div>
              <ul class="space-y-2">
                {pkg.included.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-warm-700">
                    <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="px-6 py-4 border-b border-warm-200 bg-warm-50">
              <div class="text-xs font-bold text-dark uppercase tracking-widest mb-1">
                Not included — you pay separately
              </div>
              <p class="text-[11px] text-warm-500 mb-3">
                We want you to know up front.
              </p>
              <ul class="space-y-3">
                {pkg.notIncluded.map((item) => (
                  <li class="text-sm">
                    <div class="flex items-start gap-2">
                      <svg class="w-4 h-4 text-warm-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                      <span class="font-medium text-dark">{item.label}</span>
                    </div>
                    <p class="text-xs text-warm-500 ml-6 mt-0.5">{item.note}</p>
                  </li>
                ))}
              </ul>
            </div>

            <div class="px-6 py-4 bg-primary/5 border-b border-warm-200">
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div>
                  <div class="text-xs font-bold text-primary uppercase tracking-widest">3-Year Guarantee</div>
                  <p class="text-xs text-warm-600 mt-0.5">
                    We won't force a rebuild for 3 years. <a href="#guarantee" class="text-primary underline hover:text-primary-dark">See details</a>
                  </p>
                </div>
              </div>
            </div>

            <div class="px-6 py-5 bg-white flex-1 flex flex-col justify-end">
              <p class="text-xs text-warm-500 mb-4 leading-relaxed">
                {pkg.description}
              </p>
              <a
                href="/contact"
                class:list={[
                  "block text-center px-6 py-3 rounded-xl font-semibold transition-all",
                  pkg.highlight
                    ? "bg-primary text-white hover:bg-primary-dark"
                    : "bg-dark text-white hover:bg-primary",
                ]}
              >
                {pkg.cta}
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-xs text-warm-400 mt-8 max-w-2xl mx-auto">
        * Most small business sites run on our free hosting tier. If yours would exceed it
        (heavy traffic, large media libraries), we tell you up front and show you the numbers.
      </p>
    </div>
  </section>

  <section id="why-labels" class="py-16 bg-cream border-y border-warm-200">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-4">
        Why we show pricing this way
      </h2>
      <p class="text-warm-600 leading-relaxed mb-4">
        In 2024, the FCC started requiring internet providers to show a "broadband facts" label —
        a plain-English breakdown of what a customer actually pays, not just the headline number.
        The goal was simple: stop hiding fees.
      </p>
      <p class="text-warm-600 leading-relaxed mb-4">
        Buying a website should work the same way. Too many web companies quote a low price and
        then hit you with monthly fees, plugin charges, "premium" features, and renewal price hikes.
        By the end of year two, you're paying triple what you were told.
      </p>
      <p class="text-warm-600 leading-relaxed">
        So we copied the idea. Every package above shows you the one-time cost, any required
        monthly fee (there isn't one), what's included, and what you'd pay separately — from a
        $15 domain name to stock photos. No fine print. No surprises.
      </p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Add-Ons</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">
          Need a little extra?
        </h2>
        <p class="text-warm-500">
          Add any of these to your package. Just say the word.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {addons.map((addon) => (
          <div class="flex items-center justify-between p-5 rounded-xl bg-white border border-warm-200 hover:border-primary/30 transition-colors">
            <span class="font-medium text-dark">{addon.name}</span>
            <span class="text-primary font-semibold text-sm">{addon.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Training</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">
          We teach you how to run it.
        </h2>
        <p class="text-warm-500 max-w-2xl mx-auto">
          Every site we build comes with training — not a 40-page PDF, but a real sit-down where
          we walk through everything you can update yourself. If you want more, we're happy to help.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-6 border border-warm-200">
          <div class="text-xs font-bold text-primary uppercase tracking-widest mb-2">Starter</div>
          <h3 class="text-lg font-semibold text-dark mb-2">30-min handoff</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            A walkthrough of your site and editor. How to change hours, swap a photo, update a page.
            Included at no extra charge.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border-2 border-primary">
          <div class="text-xs font-bold text-primary uppercase tracking-widest mb-2">Growth & Premium</div>
          <h3 class="text-lg font-semibold text-dark mb-2">1-hour training</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            In-depth session covering the editor, blog posts, image optimization, and basic SEO.
            Bring questions — we'll record it if you want to revisit.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-warm-200">
          <div class="text-xs font-bold text-accent uppercase tracking-widest mb-2">Add-on</div>
          <h3 class="text-lg font-semibold text-dark mb-2">Extra session — $150/hr</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            Bring on a new employee? Forgot how something works? Book another hour whenever you need
            it — no monthly commitment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="guarantee" class="py-20 md:py-28 bg-dark relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-primary-light font-semibold text-sm uppercase tracking-wider">The Guarantee</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3 mb-4">
          3 years. No forced rebuild.
        </h2>
        <p class="text-warm-400 max-w-2xl mx-auto leading-relaxed">
          Most web companies build you a site that'll look dated and run slow within two years — then
          charge you for a rebuild. Not here.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-dark-light rounded-2xl p-6 border border-warm-700">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-primary/20 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-white font-semibold">What we cover</h3>
          </div>
          <ul class="space-y-2 text-sm text-warm-300">
            <li>• Security patches & dependency updates</li>
            <li>• Framework & hosting compatibility fixes</li>
            <li>• Broken-link, broken-form, broken-feature repairs</li>
            <li>• If the site needs a full rebuild within 3 years to keep working, we do it — free.</li>
          </ul>
        </div>

        <div class="bg-dark-light rounded-2xl p-6 border border-warm-700">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-accent/20 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-white font-semibold">What it doesn't cover</h3>
          </div>
          <ul class="space-y-2 text-sm text-warm-300">
            <li>• A new redesign because you want a different look</li>
            <li>• New features or pages beyond the original scope</li>
            <li>• A business pivot that changes what the site needs to do</li>
            <li>• Third-party services outside our control (payment processors, domains)</li>
          </ul>
        </div>
      </div>

      <p class="text-center text-warm-400 text-sm mt-8 max-w-2xl mx-auto">
        Guarantee requires an active care plan for security patching. If you don't want the care plan,
        you still own your site — you just handle updates yourself.
      </p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Monthly Care Plans</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">
          We keep it running. You keep growing.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-8 border border-warm-200">
          <h3 class="text-xl font-bold text-dark mb-2">Essential</h3>
          <div class="mb-4">
            <span class="text-3xl font-extrabold text-dark">$75</span>
            <span class="text-warm-500 text-sm">/month</span>
          </div>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Hosting & security included
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Monthly checkup
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Up to 30 min of changes/month
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Email support
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Keeps your 3-year guarantee active
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 border border-warm-200">
          <h3 class="text-xl font-bold text-dark mb-2">Growth</h3>
          <div class="mb-4">
            <span class="text-3xl font-extrabold text-dark">$150</span>
            <span class="text-warm-500 text-sm">/month</span>
          </div>
          <ul class="space-y-3">
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Everything in Essential
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Up to 2 hours of changes/month
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Monthly search ranking report
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Priority support — we pick up the phone
            </li>
            <li class="flex items-center gap-3 text-sm text-warm-600">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              See your visitor numbers anytime
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>
