---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";

const whatYouGet = [
  {
    title: "Hours & Directions",
    body: "Your hours, your season, and a map to your spot, so nobody drives out to a locked gate.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    title: "A Menu of What You Sell",
    body: "Breads, honey, eggs, produce, jams, whatever's on your table, laid out clean so folks know what to come for.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  },
  {
    title: "Answers To The Usual Questions",
    body: "Do you take cards? What time should I come? Open year round? The answers sit right on the page, so you're not repeating yourself all day.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: "Tap To Call, Message, or Order",
    body: "One tap from a phone to reach you for a question, a bulk order, or a custom tray.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
  },
  {
    title: "Fresh-Batch Alerts",
    body: "Regulars sign up to get a text or email the moment a new batch is ready. No more driving out to an empty table.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>`,
  },
  {
    title: "Your Facebook, Front and Center",
    body: "Your latest posts show up right on the page, so 'peaches are in' or 'sold out today' is there without you lifting a finger.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>`,
  },
];

const payWays = [
  {
    name: "Start Monthly",
    badge: "Easiest way to start",
    price: "$150",
    unit: "down",
    sub: "then $29/mo, everything included",
    featured: true,
    points: [
      "Custom one-page design, built for you",
      "Hosting handled, always online",
      "We keep it current: hours, prices, what's fresh",
      "Cancel anytime, no long contracts",
    ],
  },
  {
    name: "Own It",
    badge: null,
    price: "$850",
    unit: "one-time",
    sub: "$150 down, the rest when it's live",
    featured: false,
    points: [
      "The same site, custom design and copy",
      "Edit it yourself anytime with a simple editor (TinaCMS)",
      "Yours to keep, along with your domain",
      "Just $9/mo hosting to stay online",
    ],
  },
];

const addOns = [
  {
    name: "Drop Alerts (text & email)",
    price: "from $150",
    desc: "Let regulars sign up to get a text or email the moment a fresh batch is ready.",
  },
  {
    name: "Photo Session",
    price: "+$150",
    desc: "A quick local shoot, so it's your real stand, table, and team on the page, not stock photos.",
  },
  {
    name: "Logo Refresh",
    price: "+$200",
    desc: "A clean, modern mark for your sign, your jars, and your new site.",
  },
  {
    name: "Label Redesign",
    price: "from $150",
    desc: "Fresh labels for your jars, jams, honey, and eggs, ready for the shelf.",
  },
];

const faqs = [
  {
    q: "What's the difference between paying monthly and owning it?",
    a: "On the monthly plan we host your site and make your edits for you, so you never have to touch it. When you own it, you pay once, it's yours to keep, and you get a simple editor to make changes yourself. Both get you the same site online. Pick whichever fits how hands-on you want to be.",
  },
  {
    q: "How do I keep it updated if I own it?",
    a: "You get a simple editor (TinaCMS) to change your hours, prices, and what's fresh yourself, no code and no developer. Your Facebook still handles the day-to-day (\"peaches are in!\"), and we can show your latest posts right on the page. Prefer we handle changes? We're glad to, for a small per-edit fee.",
  },
  {
    q: "Do I really own it?",
    a: "If you pay once, yes. The site and your domain are yours to keep and take anywhere. The monthly plan is a subscription we host and maintain for you, so you don't own it outright while you're on it, but you can switch to owning it any time. Either way, no long contracts.",
  },
  {
    q: "I already have a Facebook page. Why do I need this?",
    a: "Facebook is great, but not everyone's on it, and it won't show up when someone Googles your stand. A simple website is the one place you own and control, and it makes you look established to folks who've never met you.",
  },
  {
    q: "Can it show what's fresh today?",
    a: "Yes. We can pull your latest Facebook posts right onto the page, so \"peaches are in\" or \"sold out today\" shows up automatically, no extra work for you.",
  },
  {
    q: "Can you set up text or email alerts for my customers?",
    a: "Yes, that's the Drop Alerts add-on. We add a sign-up so regulars get a heads-up when a fresh batch is ready. The email side runs on a free service, and texts cost just a few cents each. It's a $150 setup.",
  },
  {
    q: "How long does it take?",
    a: "Most farm stand pages are ready in about a week. We can usually have you online before your next market weekend.",
  },
];
---

<Layout
  title="Farm Stand Websites from $150 Down"
  description="A simple one-page website for Greene County farm stands. Start for $150 down plus $29/mo, or own it for $850. Your menu, hours, and a map to your stand."
  hideOffer
>
  <PageHero
    eyebrow="For Greene County farm stands"
    title="Get your farm stand online."
    subtitle="One clean page that shows folks what you sell, when you're open, and how to find you, plus a way to tell them the moment fresh batches hit the table. Built local, priced small, and yours to keep."
    image="/farm-stand-hero.jpg"
  >
    <div class="mt-8 flex flex-col sm:flex-row sm:flex-wrap gap-3 justify-center">
      <a
        href="#start"
        class="inline-flex items-center justify-center px-8 py-4 bg-accent text-dark font-semibold rounded-xl hover:bg-accent-dark transition-all hover:shadow-xl hover:shadow-accent/30 hover:-translate-y-0.5"
      >
        Claim the Farm Stand Special
      </a>
      <a
        href="#example"
        class="inline-flex items-center justify-center px-8 py-4 border border-white/40 bg-white/5 backdrop-blur-sm text-white font-semibold rounded-xl hover:border-white hover:bg-white/10 transition-all"
      >
        See an Example
      </a>
    </div>
    <p class="mt-5 text-sm text-white/70">Start for $150 down, or own it for $850</p>
  </PageHero>

  <!-- What you get -->
  <section id="whats-included" class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14" data-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">What you get</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">Everything a stand needs. Nothing it doesn't.</h2>
        <p class="text-warm-600 max-w-2xl mx-auto">One clean page that helps local folks find you, trust you, and know what came out of the oven this morning, without a bunch of tech or monthly junk.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {whatYouGet.map((item, i) => (
          <div class="bg-white rounded-2xl p-6 border border-warm-200 shadow-sm" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
            </div>
            <h3 class="font-bold text-dark mb-1">{item.title}</h3>
            <p class="text-warm-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Demo showcase -->
  <section id="example" class="py-20 md:py-28 bg-cream border-t border-warm-200">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12" data-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">A real example</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">See what your stand's site could look like.</h2>
        <p class="text-warm-600 max-w-2xl mx-auto">This is a sample farm stand site we designed, top to bottom. Yours would be built around your own products, photos, and season.</p>
      </div>

      <figure class="max-w-3xl mx-auto rounded-2xl overflow-hidden border border-warm-200 shadow-xl bg-white" data-reveal>
        <div class="flex items-center gap-1.5 px-3 py-2.5 bg-warm-100 border-b border-warm-200">
          <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-warm-300"></span>
          <span class="ml-3 text-[11px] text-warm-500 truncate">willowcreekfarmstand.com</span>
        </div>
        <img
          src="/farm-stand-custom-website.jpg"
          alt="Example one-page farm stand website built by Made in Greene"
          class="w-full h-auto"
          loading="lazy"
        />
      </figure>

      <div class="max-w-3xl mx-auto mt-10 space-y-10" data-reveal>
        <figure>
          <img src="/farm-stand-product-showcase.jpg" alt="Product showcase on the example farm stand site" class="w-full h-auto rounded-xl border border-warm-200 shadow-sm" loading="lazy" />
          <figcaption class="text-center mt-4">
            <span class="block text-sm font-bold text-dark">A menu of what you sell</span>
            <span class="block text-sm text-warm-600 mt-1 max-w-md mx-auto">Breads, honey, cookies, and more, each with a name, a price, and a photo, so folks know what's on the table before they drive out.</span>
          </figcaption>
        </figure>
        <figure>
          <img src="/farm-stand-featured-drops.jpg" alt="Fresh-batch alerts on the example farm stand site" class="w-full h-auto rounded-xl border border-warm-200 shadow-sm" loading="lazy" />
          <figcaption class="text-center mt-4">
            <span class="block text-sm font-bold text-dark">Fresh-batch alerts</span>
            <span class="block text-sm text-warm-600 mt-1 max-w-md mx-auto">A sign-up right on the page, so regulars get a text or email the moment a fresh batch is ready and never miss the good stuff.</span>
          </figcaption>
        </figure>
        <figure>
          <img src="/farm-stand-hours.jpg" alt="Hours and directions on the example farm stand site" class="w-full h-auto rounded-xl border border-warm-200 shadow-sm" loading="lazy" />
          <figcaption class="text-center mt-4">
            <span class="block text-sm font-bold text-dark">Hours &amp; directions</span>
            <span class="block text-sm text-warm-600 mt-1 max-w-md mx-auto">Your days, your hours, and a map to your spot, plus a note for when you close up for the season, so nobody drives out for nothing.</span>
          </figcaption>
        </figure>
      </div>

      <div class="mt-12 flex flex-col sm:flex-row gap-3 justify-center" data-reveal>
        <a
          href="https://farmstanddemo.netlify.app/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5"
        >
          View the Live Demo
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <a
          href="#start"
          class="inline-flex items-center justify-center px-8 py-4 border border-warm-300 text-dark font-semibold rounded-xl hover:border-primary hover:text-primary transition-all"
        >
          Get my stand online
        </a>
      </div>
    </div>
  </section>

  <!-- Logo refresh showcase -->
  <section class="py-20 md:py-28 bg-white border-t border-warm-200">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-10" data-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Logo refresh</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">A little polish goes a long way.</h2>
        <p class="text-warm-600 max-w-2xl mx-auto">
          We freshened up The Funny Farm's logo as part of their site. Same character, just cleaner
          and ready for signs, jars, and the web. Add a refresh to your stand for just $200.
        </p>
      </div>
      <figure class="rounded-2xl overflow-hidden border border-warm-200 shadow-sm bg-cream" data-reveal>
        <img
          src="/baf-funny-farm-logo.webp"
          alt="Before and after of The Funny Farm logo refresh"
          class="w-full h-auto"
          loading="lazy"
        />
      </figure>
      <p class="text-center text-sm text-warm-500 mt-4" data-reveal>Before and after — The Funny Farm, Chuckey, TN.</p>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="py-20 md:py-28 bg-warm-100 border-t border-warm-200">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14" data-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Simple pricing</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">Two ways to get your stand online.</h2>
        <p class="text-warm-600 max-w-2xl mx-auto">Start for a little and pay monthly, or pay once and own it. Same site either way, and we'll always tell you the cost up front.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {payWays.map((way) => (
          <div
            class:list={[
              "rounded-2xl p-7 flex flex-col relative",
              way.featured ? "bg-white ring-2 ring-primary shadow-xl shadow-primary/10" : "bg-white border border-warm-200 shadow-sm",
            ]}
            data-reveal
          >
            {way.badge && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-accent text-warm-900 text-[10px] font-bold uppercase tracking-wider rounded-full shadow-md whitespace-nowrap">
                {way.badge}
              </span>
            )}
            <h3 class="text-lg font-bold text-dark">{way.name}</h3>
            <div class="flex items-baseline gap-1.5 mt-2 mb-1">
              <span class="text-4xl font-extrabold text-dark">{way.price}</span>
              <span class="text-sm text-warm-500">{way.unit}</span>
            </div>
            <p class="text-sm font-semibold text-primary mb-5">{way.sub}</p>
            <ul class="space-y-2.5 flex-1 mb-6">
              {way.points.map((p) => (
                <li class="flex items-start gap-2.5 text-sm text-warm-700">
                  <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
            <a
              href="#start"
              class:list={[
                "block text-center px-6 py-3 rounded-xl font-semibold text-sm transition-all mt-auto",
                way.featured ? "bg-primary text-white hover:bg-primary-dark" : "bg-dark text-white hover:bg-primary",
              ]}
            >
              Get started
            </a>
          </div>
        ))}
      </div>

      <div class="mt-14" data-reveal>
        <h3 class="text-center text-sm font-bold text-dark uppercase tracking-widest mb-6">Make it yours (optional)</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto">
          {addOns.map((addon) => (
            <div class="flex items-start justify-between gap-4 p-5 rounded-xl bg-white border border-warm-200">
              <div>
                <span class="font-semibold text-dark">{addon.name}</span>
                <p class="text-sm text-warm-500 mt-0.5 leading-relaxed">{addon.desc}</p>
              </div>
              <span class="text-primary font-bold text-sm shrink-0">{addon.price}</span>
            </div>
          ))}
        </div>
      </div>

      <p class="text-center text-sm text-warm-500 mt-10" data-reveal>
        Domain (about $12–20/yr, in your name) is the only outside cost, and we'll help you get it.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-28 bg-cream border-t border-warm-200">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12" data-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Good to know</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3">Questions farm stand owners ask.</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <div class="bg-white rounded-2xl border border-warm-200 p-6" data-reveal>
            <h3 class="text-lg font-semibold text-dark mb-2">{faq.q}</h3>
            <p class="text-warm-600 leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Start / form -->
  <section id="start" class="py-20 md:py-28 bg-warm-100 border-t border-warm-200 scroll-mt-20">
    <div class="max-w-2xl mx-auto px-6">
      <div class="text-center mb-10" data-reveal>
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Let's do it</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">Claim the Farm Stand Special.</h2>
        <p class="text-warm-600 max-w-xl mx-auto">
          Tell us a little about your stand and we'll get you set up, usually before your next market weekend. No pressure, and we'll confirm everything before we start.
        </p>
      </div>

      <form
        name="farm-stand"
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        action="/thank-you/"
        class="bg-white rounded-2xl p-8 border border-warm-200 shadow-sm"
        data-reveal
      >
        <input type="hidden" name="form-name" value="farm-stand" />
        <input type="hidden" name="offer" value="Farm Stand Special" />
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>

        <div class="space-y-5">
          <div>
            <label for="fs-name" class="block text-sm font-medium text-dark mb-2">Your name</label>
            <input type="text" id="fs-name" name="name" required
              class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
              placeholder="Your name" />
          </div>
          <div>
            <label for="fs-stand" class="block text-sm font-medium text-dark mb-2">Farm stand name</label>
            <input type="text" id="fs-stand" name="stand"
              class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
              placeholder="Your stand's name" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="fs-email" class="block text-sm font-medium text-dark mb-2">Email</label>
              <input type="email" id="fs-email" name="email" required
                class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                placeholder="you@example.com" />
            </div>
            <div>
              <label for="fs-phone" class="block text-sm font-medium text-dark mb-2">Phone (optional)</label>
              <input type="tel" id="fs-phone" name="phone"
                class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                placeholder="(423) 555-0100" />
            </div>
          </div>

          <div>
            <label for="fs-pay" class="block text-sm font-medium text-dark mb-2">How would you like to pay?</label>
            <select id="fs-pay" name="payment"
              class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors">
              <option value="">Not sure yet, let's talk</option>
              <option value="monthly">Start monthly ($150 down + $29/mo)</option>
              <option value="own">Own it ($850 one-time)</option>
            </select>
          </div>

          <fieldset>
            <legend class="block text-sm font-medium text-dark mb-2">Interested in any add-ons?</legend>
            <div class="space-y-2.5">
              <label class="flex items-center gap-3 text-sm text-warm-700">
                <input type="checkbox" name="addons" value="Logo Refresh (+$200)" class="w-4 h-4 rounded border-warm-300 text-primary focus:ring-primary/40" />
                Logo refresh (+$200)
              </label>
              <label class="flex items-center gap-3 text-sm text-warm-700">
                <input type="checkbox" name="addons" value="Label Redesign (from $150)" class="w-4 h-4 rounded border-warm-300 text-primary focus:ring-primary/40" />
                Label redesign (from $150)
              </label>
              <label class="flex items-center gap-3 text-sm text-warm-700">
                <input type="checkbox" name="addons" value="Drop Alerts (from $150)" class="w-4 h-4 rounded border-warm-300 text-primary focus:ring-primary/40" />
                Drop alerts, text &amp; email (from $150)
              </label>
              <label class="flex items-center gap-3 text-sm text-warm-700">
                <input type="checkbox" name="addons" value="Photo Session (+$150)" class="w-4 h-4 rounded border-warm-300 text-primary focus:ring-primary/40" />
                Photo session (+$150)
              </label>
            </div>
          </fieldset>

          <div>
            <label for="fs-message" class="block text-sm font-medium text-dark mb-2">Tell us about your stand</label>
            <textarea id="fs-message" name="message" rows="3"
              class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors resize-none"
              placeholder="What do you sell, and where are you located?"></textarea>
          </div>

          <button type="submit"
            class="w-full px-6 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/25">
            Claim the Farm Stand Special
          </button>
          <p class="text-xs text-warm-400 text-center">
            Free to ask. No pressure, and you don't need your photos or wording ready yet.
          </p>
        </div>
      </form>
    </div>
  </section>
</Layout>
