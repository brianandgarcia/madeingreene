---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CTA from "../components/CTA.astro";

const comparisonRows = [
  {
    category: "Pricing model",
    godaddy: "Lower upfront cost with ongoing subscription pricing and add-ons",
    us: "One-time build with optional care plan",
  },
  {
    category: "How it gets built",
    godaddy: "DIY website builder with templates",
    us: "Custom site built for your business",
  },
  {
    category: "Ownership",
    godaddy: "Your domain can be yours, but the builder experience stays tied to the platform",
    us: "You own your domain and site files",
  },
  {
    category: "Editing after launch",
    godaddy: "You handle edits inside the builder",
    us: "Edit it yourself or have us help",
  },
  {
    category: "Local search setup",
    godaddy: "DIY tools and paid add-ons",
    us: "Done-for-you setup as part of the build",
  },
  {
    category: "Support",
    godaddy: "Large support organization",
    us: "Direct local support",
  },
  {
    category: "Best fit",
    godaddy: "Good for fast DIY launches",
    us: "Good for businesses that want it built for them",
  },
  {
    category: "Design flexibility",
    godaddy: "Template-based",
    us: "Built around your brand and goals",
  },
];

const comparisonPaths = [
  {
    label: "Option A",
    title: "DIY builder route",
    intro:
      "Best when you need something online quickly and you are comfortable building it, editing it, and managing the tradeoffs yourself.",
    bullets: [
      "Lower entry cost",
      "Template-based design",
      "You do most of the setup and ongoing changes",
      "Good for simple DIY launches",
    ],
  },
  {
    label: "Option B",
    title: "Done-for-you local route",
    intro:
      "Best when you want a site that feels professional, fits your business, and comes with a local person to talk to if you need help.",
    bullets: [
      "Custom build around your business",
      "Clear upfront pricing",
      "Local search setup handled with you",
      "Direct support after launch if you want it",
    ],
  },
];
---

<Layout
  title="GoDaddy vs. a Custom Website"
  description="A plain-English comparison of GoDaddy's website builder vs a custom site from Made in Greene. Real numbers, no marketing spin."
>
  <PageHero
    eyebrow="The Comparison"
    title="Why not just use GoDaddy?"
    subtitle="It's a fair question. Entry-level DIY builder pricing can sound great until renewals, add-ons, and limitations show up. That does not make it bad — it just makes it a different choice."
    image="/03-trust-signal.png"
  />

  <section class="py-16 bg-cream border-y border-warm-200">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-4">
        What they sell you. What they don't.
      </h2>
      <p class="text-warm-600 leading-relaxed mb-4">
        GoDaddy's website builder is a subscription product. For some businesses, that is a fine
        fit. You trade a lower upfront cost for a more DIY setup, a platform-based workflow, and a
        stack of add-ons or upgrades if your needs grow.
      </p>
      <p class="text-warm-600 leading-relaxed">
        Hiring a local shop like us is a different model. You are paying for a site to be planned,
        written, designed, and built around your business instead of assembled by you inside a
        template builder.
      </p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Side by Side</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">
          The honest comparison.
        </h2>
      </div>

      <div class="bg-white rounded-2xl border-2 border-dark overflow-hidden shadow-sm">
        <div class="grid grid-cols-3 bg-dark text-white">
          <div class="px-4 md:px-6 py-4 text-xs md:text-sm font-bold uppercase tracking-wider">What you're comparing</div>
          <div class="px-4 md:px-6 py-4 text-xs md:text-sm font-bold uppercase tracking-wider border-l border-warm-700">GoDaddy</div>
          <div class="px-4 md:px-6 py-4 text-xs md:text-sm font-bold uppercase tracking-wider border-l border-warm-700 bg-primary">Made in Greene</div>
        </div>
        {comparisonRows.map((row, i) => (
          <div class:list={[
            "grid grid-cols-3 border-t border-warm-200",
            i % 2 === 1 && "bg-warm-50",
          ]}>
            <div class="px-4 md:px-6 py-4 text-sm font-semibold text-dark">
              {row.category}
            </div>
            <div class="px-4 md:px-6 py-4 text-sm text-warm-600 border-l border-warm-200">
              {row.godaddy}
            </div>
            <div class="px-4 md:px-6 py-4 text-sm text-dark font-medium border-l border-warm-200 bg-primary/5">
              {row.us}
            </div>
          </div>
        ))}
      </div>

      <p class="text-xs text-warm-400 mt-4 text-center max-w-2xl mx-auto">
        Platform features and pricing change often, so it is worth checking current details
        directly before you compare.
      </p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-primary font-semibold text-sm uppercase tracking-wider">Two Paths Online</span>
        <h2 class="text-3xl md:text-4xl font-bold text-dark mt-3 mb-4">
          What you're really choosing between.
        </h2>
        <p class="text-warm-500 max-w-2xl mx-auto">
          This is less about one company being good or bad, and more about which setup fits how you
          want to work.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {comparisonPaths.map((path, index) => (
          <div
            class:list={[
              "bg-white rounded-2xl overflow-hidden",
              index === 0
                ? "border-2 border-warm-300"
                : "border-2 border-primary shadow-xl shadow-primary/10",
            ]}
          >
            <div class:list={[
              "px-6 py-4",
              index === 0 ? "bg-warm-200" : "bg-primary",
            ]}>
              <div class:list={[
                "text-xs uppercase tracking-widest mb-1",
                index === 0 ? "text-warm-600" : "text-white/80",
              ]}>
                {path.label}
              </div>
              <h3 class:list={[
                "text-xl font-bold",
                index === 0 ? "text-dark" : "text-white",
              ]}>
                {path.title}
              </h3>
            </div>
            <div class="px-6 py-5">
              <p class="text-warm-600 leading-relaxed mb-5">
                {path.intro}
              </p>
              <ul class="space-y-3">
                {path.bullets.map((bullet) => (
                  <li class="flex items-start gap-3 text-sm text-warm-600">
                    <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-3xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-4">
          Where GoDaddy does make sense
        </h2>
        <p class="text-warm-500">
          We don't think they're villains. A few honest cases where they're the right call.
        </p>
      </div>

      <div class="space-y-4">
        <div class="bg-white rounded-2xl p-6 border border-warm-200">
          <h3 class="font-semibold text-dark mb-2">You just need to park a domain name</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            GoDaddy's fine for buying and holding a domain. So is Cloudflare, Namecheap, or Porkbun —
            often cheaper. Buy your domain there; don't let anyone else hold it for you.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-warm-200">
          <h3 class="font-semibold text-dark mb-2">You want a one-page site up tonight and you'll never touch it again</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            Drag-and-drop builders are quick. If you genuinely need something live in the next
            hour and the budget is zero, go for it. Know what you're getting.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-warm-200">
          <h3 class="font-semibold text-dark mb-2">You're testing an idea and might abandon it</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            For a side project you're not sure will stick, the low first-year cost makes sense.
            Just remember to cancel before the renewal hits if it doesn't pan out.
          </p>
        </div>
      </div>

      <p class="text-center text-warm-500 mt-10">
        If your business is any of those, we'll tell you honestly — and send you on your way.
        For everything else, there's a better way.
      </p>
    </div>
  </section>

  <CTA />
</Layout>
