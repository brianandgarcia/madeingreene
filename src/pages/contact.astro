---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact" description="Get a free quote for your small business website. MadeinGreene — your neighbor in web development, Greene County, TN.">
  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">Get In Touch</span>
          <h1 class="text-3xl md:text-5xl font-bold text-dark mt-3 mb-6">
            Pull up a chair. Let's talk.
          </h1>
          <p class="text-lg text-warm-500 leading-relaxed mb-10">
            Tell us a little about your business and what you're looking for. We'll get back to you within a day with some ideas and a straight quote — no strings, no pressure.
          </p>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Email</h3>
                <a href="mailto:hello@madeingreene.com" class="text-warm-500 hover:text-primary transition-colors">
                  hello@madeingreene.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Location</h3>
                <p class="text-warm-500">Greene County, Tennessee</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Response Time</h3>
                <p class="text-warm-500">Within 24 hours — usually sooner</p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <form class="bg-white rounded-2xl p-8 border border-warm-200 shadow-sm">
            <div class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium text-dark mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="Your name"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-dark mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="you@example.com"
                />
              </div>

              <div>
                <label for="business" class="block text-sm font-medium text-dark mb-2">Business Name</label>
                <input
                  type="text"
                  id="business"
                  name="business"
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="Your business name"
                />
              </div>

              <div>
                <label for="package" class="block text-sm font-medium text-dark mb-2">What are you looking for?</label>
                <select
                  id="package"
                  name="package"
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                >
                  <option value="">Pick one...</option>
                  <option value="starter">Starter Site ($1,500)</option>
                  <option value="growth">Growth Site ($3,500)</option>
                  <option value="premium">Premium / Custom ($5,000+)</option>
                  <option value="unsure">Not sure yet — just want to talk</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-dark mb-2">Tell us about your business</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors resize-none"
                  placeholder="What do you do? What would you want your website to help with?"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full px-6 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/25"
              >
                Send It Over
              </button>

              <p class="text-xs text-warm-400 text-center">
                Free quote. No obligation. We'll just get back to you.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
