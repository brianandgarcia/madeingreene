---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout title="Contact — Free Website Quote" description="Get a free quote for a small business website from Made in Greene. Clear pricing and local support for Greene County businesses.">
  <PageHero
    eyebrow="Get In Touch"
    title="Tell us about your business."
    subtitle="Tell us what you do and what you want the site to help with — we'll recommend the best fit and send a no-pressure quote within 1 business day."
    image="/home-greene-quote-bg.jpg"
  />

  <section class="py-20 md:py-28 bg-warm-100">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-dark mb-6">
            Other ways to reach us.
          </h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Email</h3>
                <a href="mailto:brian@madeingreene.com" class="text-warm-500 hover:text-primary transition-colors">
                  brian@madeingreene.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Location</h3>
                <p class="text-warm-500">Greene County, Tennessee</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-dark">Response Time</h3>
                <p class="text-warm-500">Within 1 business day</p>
              </div>
            </div>
          </div>

          <div class="mt-10 rounded-2xl bg-white border border-warm-200 p-6">
            <h3 class="text-lg font-semibold text-dark mb-3">What happens next</h3>
            <ul class="space-y-3 text-sm text-warm-600">
              <li>We read through your note and figure out what kind of site fits best.</li>
              <li>We recommend a package or tell you if a custom quote makes more sense.</li>
              <li>We send a free quote within 1 business day.</li>
              <li>You do not need your photos, wording, or package picked out before reaching out.</li>
            </ul>
          </div>
        </div>

        <div>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            action="/thank-you/"
            class="bg-white rounded-2xl p-8 border border-warm-200 shadow-sm"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
            </p>
            <div class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium text-dark mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="Your name"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-dark mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="you@example.com"
                />
              </div>

              <div>
                <label for="business" class="block text-sm font-medium text-dark mb-2">Business Name</label>
                <input
                  type="text"
                  id="business"
                  name="business"
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                  placeholder="Your business name"
                />
              </div>

              <div>
                <label for="package" class="block text-sm font-medium text-dark mb-2">What are you looking for?</label>
                <select
                  id="package"
                  name="package"
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
                >
                  <option value="">Pick one...</option>
                  <option value="landing">Local Landing Page ($1,250)</option>
                  <option value="business">Business Website ($3,000)</option>
                  <option value="growth">Growth Website ($4,500)</option>
                  <option value="ecommerce">Ecommerce Website ($5,500+)</option>
                  <option value="unsure">Not sure yet — just want to talk</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-dark mb-2">Tell us about your business</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full px-4 py-3 rounded-xl border border-warm-300 text-dark placeholder-warm-400 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors resize-none"
                  placeholder="What do you do? What would you want your website to help with?"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full px-6 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/25"
              >
                Get My Free Quote
              </button>

              <p class="text-xs text-warm-400 text-center">
                Free quote. No pressure. You do not need all your content ready yet.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
